rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── 사용자 프로필 ───
    match /users/{userId} {
      // 본인만 읽기/쓰기
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── 교회 데이터 ───
    match /churches/{churchCode} {
      // 교회 정보: 인증된 사용자만 읽기
      allow read: if request.auth != null;
      // 교회 생성/수정: 관리자만 (adminUids 필드에 포함)
      allow write: if request.auth != null
        && request.auth.uid in resource.data.adminUids;

      // 설교
      match /sermons/{sermonId} {
        // 같은 교회 교인만 읽기
        allow read: if request.auth != null;
        // 관리자만 쓰기
        allow create, update, delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/churches/$(churchCode)).data.adminUids;
      }

      // 교인 목록
      match /members/{memberId} {
        // 관리자만 전체 목록 읽기, 본인은 자기 정보 읽기
        allow read: if request.auth != null;
        // 본인 정보 수정 또는 관리자
        allow write: if request.auth != null
          && (request.auth.uid == memberId
            || request.auth.uid in get(/databases/$(database)/documents/churches/$(churchCode)).data.adminUids);

        // 기도 기록 (하위 컬렉션)
        match /prayers/{prayerId} {
          allow read, write: if request.auth != null;
        }
      }

      // 공지사항
      match /notices/{noticeId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/churches/$(churchCode)).data.adminUids;
      }
    }

    // ─── 사용자 진행률 ───
    match /userProgress/{docId} {
      // 본인만 읽기/쓰기 (churchCode + uid 기반)
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
      // 새로 생성 시
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // ─── 기도제목 ───
    match /users/{userId}/prayer_requests/{prayerId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── 교단/학교 공지 (읽기 전용) ───
    match /denomination_notices/{noticeId} {
      allow read: if request.auth != null;
      // 쓰기는 Firebase Admin SDK로만 (서버 측)
      allow write: if false;
    }

    // ─── 기본: 모두 차단 ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
